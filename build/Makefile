test_async_worker: cmake_check_build_system
	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 test_async_worker
.PHONY : test_async_worker

# fast build rule for target.
test_async_worker/fast:
	$(MAKE) $(MAKESILENT) -f tests/test_async_worker/CMakeFiles/test_async_worker.dir/build.make tests/test_async_worker/CMakeFiles/test_async_worker.dir/build
.PHONY : test_async_worker/fast

